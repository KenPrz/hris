# Root .env — read by compose.dev.yml only. The backend has its own backend/.env
# for native (non-container) runs.

# Mint with `make dev-key`, then paste the value here.
HRIS_DEV_APP_KEY=

HRIS_DEV_DB_PASSWORD=hris

# Host ports. Defaults avoid ../pos, which holds 5432/8000/5174/5175.
HRIS_DEV_DB_PORT=5433
HRIS_DEV_API_PORT=8001
HRIS_DEV_WEB_PORT=5176
