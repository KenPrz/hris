# Overrides for compose.dev.yml. Copy to .env to change defaults; both have
# sane defaults baked into compose.dev.yml and do not need to be set.

# Host port the db container's 5432 is published on. 5433, not 5432 —
# ../pos holds 5432 on this host.
HRIS_DEV_DB_PORT=5433

# Postgres superuser password inside the dev container only. Not used by
# anything outside this machine's Docker network.
HRIS_DEV_DB_PASSWORD=hris
