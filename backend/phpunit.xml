<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
        <testsuite name="Arch">
            <directory>tests/Arch</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <php>
        <env name="APP_ENV" value="testing"/>
        <env name="APP_MAINTENANCE_DRIVER" value="file"/>
        <env name="APP_TIMEZONE" value="UTC"/>
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="CACHE_STORE" value="array"/>
        <!--
            Real Postgres, never SQLite. We depend on SELECT ... FOR UPDATE, partial
            unique indexes, jsonb, timestamptz and exclusion constraints; SQLite
            silently lacks all of them, so a green SQLite suite would actively mislead
            about whether our concurrency invariants hold. See docs/01-architecture.md.
        -->
        <env name="DB_CONNECTION" value="pgsql"/>
        <env name="DB_HOST" value="127.0.0.1"/>
        <env name="DB_PORT" value="5433"/>
        <env name="DB_DATABASE" value="hris_test"/>
        <env name="DB_USERNAME" value="hris"/>
        <env name="DB_PASSWORD" value="hris"/>
        <env name="DB_URL" value=""/>
        <env name="HRIS_VERSION" value="test"/>
        <env name="HRIS_CURRENCY" value="PHP"/>
        <env name="HRIS_ORGANIZATION_NAME" value="Test Company Inc."/>
        <env name="MAIL_MAILER" value="array"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <env name="SESSION_DRIVER" value="array"/>
    </php>
</phpunit>
